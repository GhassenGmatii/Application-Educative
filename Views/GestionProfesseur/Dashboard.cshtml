@{
    ViewData["Title"] = "Dashboard Professeur";
    var prof = ViewBag.Prof as Application_Educative.Models.Professeur;
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    .welcome-card { background: linear-gradient(135deg, #1a3c6e, #2e6db4); color: white; border-radius: 16px; padding: 30px; margin-bottom: 25px; }
    .stat-card { border-radius: 12px; padding: 22px; color: white; box-shadow: 0 4px 15px rgba(0,0,0,0.15); height: 100%; }
    .stat-card.blue { background: linear-gradient(135deg, #007bff, #0056b3); }
    .stat-card.red { background: linear-gradient(135deg, #dc3545, #b02a37); }
    .stat-card.teal { background: linear-gradient(135deg, #17a2b8, #117a8b); }
    .section-badge { background: rgba(255,255,255,0.2); border-radius: 20px; padding: 5px 14px; font-size: 13px; margin: 3px; display: inline-block; }
    .card-recent { border-radius: 14px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); overflow: hidden; }
    .table thead th { background: #1a3c6e; color: white; border: none; padding: 12px 16px; }
    .table tbody td { padding: 12px 16px; vertical-align: middle; }
    .btn-absence { background: linear-gradient(135deg, #6f42c1, #4e2d8a); color: white; border: none; border-radius: 10px; padding: 10px 22px; font-weight: 600; transition: all 0.2s; }
    .btn-absence:hover { transform: translateY(-2px); color: white; }
</style>

<div class="container-fluid py-4">

    <!-- Welcome -->
    <div class="welcome-card d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <h2 class="mb-1">
                <i class="fas fa-chalkboard-teacher me-2"></i>
                Bonjour, @prof?.FirstName @prof?.LastName ! 👋
            </h2>
            <p class="mb-2 opacity-75">
                <i class="fas fa-graduation-cap me-1"></i>@prof?.Specialite
                &nbsp;|&nbsp;
                <i class="fas fa-envelope me-1"></i>@prof?.Email
            </p>
            <div>
                @if (prof?.ProfesseurSections != null && prof.ProfesseurSections.Any())
                {
                    foreach (var ps in prof.ProfesseurSections)
                    {
                        <span class="section-badge">
                            <i class="fas fa-layer-group me-1"></i>
                            @ps.Section?.Nom — @ps.Section?.Niveau
                            (@ps.NombreHeures h/sem)
                        </span>
                    }
                }
                else
                {
                    <span class="section-badge">
                        <i class="fas fa-info-circle me-1"></i>Aucune section affectée
                    </span>
                }
            </div>
        </div>
        <a href="/Absence/Create" class="btn btn-absence">
            <i class="fas fa-plus me-2"></i>Saisir une absence
        </a>
    </div>

    <!-- Stats -->
    <div class="row mb-4">
        <div class="col-md-4 mb-3">
            <div class="stat-card blue">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="mb-1 opacity-75">Mes sections</p>
                        <h3 class="mb-0 fw-bold">@(prof?.ProfesseurSections?.Count ?? 0)</h3>
                    </div>
                    <i class="fas fa-layer-group fa-2x opacity-75"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="stat-card teal">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="mb-1 opacity-75">Absences saisies</p>
                        <h3 class="mb-0 fw-bold">@ViewBag.TotalAbsences</h3>
                    </div>
                    <i class="fas fa-calendar-times fa-2x opacity-75"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="stat-card red">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="mb-1 opacity-75">Non justifiées</p>
                        <h3 class="mb-0 fw-bold">@ViewBag.AbsencesNonJustifiees</h3>
                    </div>
                    <i class="fas fa-times-circle fa-2x opacity-75"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Absences récentes -->
    <div class="card card-recent">
        <div class="card-header bg-white d-flex justify-content-between align-items-center py-3 px-4">
            <h5 class="mb-0 fw-bold">
                <i class="fas fa-clock me-2 text-primary"></i>Absences récentes
            </h5>
            <a href="/Absence/Index" class="btn btn-sm btn-outline-primary">
                <i class="fas fa-list me-1"></i>Voir tout
            </a>
        </div>
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th><i class="fas fa-user me-1"></i>Étudiant</th>
                    <th><i class="fas fa-book me-1"></i>Matière</th>
                    <th><i class="fas fa-layer-group me-1"></i>Section</th>
                    <th><i class="fas fa-calendar me-1"></i>Date</th>
                    <th><i class="fas fa-info-circle me-1"></i>Statut</th>
                </tr>
            </thead>
            <tbody>
                @if (ViewBag.RecentAbsences != null)
                {
                    bool hasRows = false;
                    foreach (var abs in ViewBag.RecentAbsences)
                    {
                        hasRows = true;
                        <tr>
                            <td><strong>@abs.Etudiant?.Prenom @abs.Etudiant?.Nom</strong></td>
                            <td>@abs.Matiere?.Nom</td>
                            <td><span class="badge bg-light text-dark border">@abs.Section?.Nom</span></td>
                            <td>@abs.DateAbsence.ToString("dd/MM/yyyy")</td>
                            <td>
                                @if (abs.Justifiee)
                                {
                                    <span class="badge bg-success">Justifiée</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Non justifiée</span>
                                }
                            </td>
                        </tr>
                    }
                    if (!hasRows)
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">
                                <i class="fas fa-calendar-check me-2"></i>Aucune absence saisie
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-4 text-muted">
                            <i class="fas fa-calendar-check me-2"></i>Aucune absence saisie
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>