@{
    ViewData["Title"] = "Mon Espace";
    var etudiant = ViewBag.Etudiant as Application_Educative.Models.Etudiant;
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    .welcome-card { background: linear-gradient(135deg, #28a745, #1e7e34); color: white; border-radius: 16px; padding: 30px; margin-bottom: 25px; }
    .stat-card { border-radius: 12px; padding: 22px; color: white; box-shadow: 0 4px 15px rgba(0,0,0,0.15); height: 100%; }
    .stat-card.purple { background: linear-gradient(135deg, #6f42c1, #4e2d8a); }
    .stat-card.red { background: linear-gradient(135deg, #dc3545, #b02a37); }
    .stat-card.green { background: linear-gradient(135deg, #28a745, #1e7e34); }
    .card-absences { border-radius: 14px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); overflow: hidden; }
    .table thead th { background: #28a745; color: white; border: none; padding: 12px 16px; }
    .table tbody td { padding: 12px 16px; vertical-align: middle; }
    .info-badge { background: rgba(255,255,255,0.2); border-radius: 20px; padding: 5px 14px; font-size: 13px; margin: 3px; display: inline-block; }
    .progress-bar-custom { height: 10px; border-radius: 10px; }
</style>

<div class="container-fluid py-4">

    <!-- Welcome -->
    <div class="welcome-card">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
            <div>
                <h2 class="mb-1">
                    <i class="fas fa-user-graduate me-2"></i>
                    Bonjour, @etudiant?.Prenom @etudiant?.Nom ! 👋
                </h2>
                <p class="mb-2 opacity-75">Bienvenue dans votre espace étudiant</p>
                <div>
                    <span class="info-badge"><i class="fas fa-layer-group me-1"></i>@etudiant?.Section</span>
                    <span class="info-badge"><i class="fas fa-tag me-1"></i>@etudiant?.Specialite</span>
                    
                    <span class="info-badge">
                        @if (etudiant?.Etat == "Admis")
                        {
                            <i class="fas fa-check me-1"></i>
                        }
                        else
                        {
                            <i class="fas fa-redo me-1"></i>
                        }
                        @etudiant?.Etat
                    </span>
                </div>
            </div>
            <div class="text-end">
                <p class="mb-1 opacity-75 small">Inscrit le</p>
                <strong>@etudiant?.DateCreation.ToString("dd/MM/yyyy")</strong>
            </div>
        </div>
    </div>

    <!-- Stats -->
    <div class="row mb-4">
        <div class="col-md-4 mb-3">
            <div class="stat-card purple">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="mb-1 opacity-75">Total absences</p>
                        <h3 class="mb-0 fw-bold">@ViewBag.TotalAbsences</h3>
                    </div>
                    <i class="fas fa-calendar-times fa-2x opacity-75"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="stat-card green">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="mb-1 opacity-75">Justifiées</p>
                        <h3 class="mb-0 fw-bold">@ViewBag.Justifiees</h3>
                    </div>
                    <i class="fas fa-check-circle fa-2x opacity-75"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="stat-card red">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="mb-1 opacity-75">Non justifiées</p>
                        <h3 class="mb-0 fw-bold">@ViewBag.NonJustifiees</h3>
                    </div>
                    <i class="fas fa-times-circle fa-2x opacity-75"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Barre de progression absences -->
    @if (ViewBag.TotalAbsences > 0)
    {
        int pct = (int)((ViewBag.Justifiees / (double)ViewBag.TotalAbsences) * 100);
        <div class="card p-4 mb-4" style="border-radius:14px; box-shadow:0 4px 20px rgba(0,0,0,0.08);">
            <div class="d-flex justify-content-between mb-2">
                <span class="fw-bold"><i class="fas fa-chart-bar me-1 text-success"></i>Taux de justification</span>
                <span class="fw-bold text-success">@pct%</span>
            </div>
            <div class="progress progress-bar-custom">
                <div class="progress-bar bg-success" style="width: @pct%"></div>
            </div>
        </div>
    }

    <!-- Liste des absences -->
    <div class="card card-absences">
        <div class="card-header bg-white d-flex justify-content-between align-items-center py-3 px-4">
            <h5 class="mb-0 fw-bold"><i class="fas fa-calendar-times me-2 text-success"></i>Mes absences</h5>
            <span class="badge bg-secondary">@ViewBag.TotalAbsences absence(s)</span>
        </div>
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th><i class="fas fa-book me-1"></i>Matière</th>
                    <th><i class="fas fa-layer-group me-1"></i>Section</th>
                    <th><i class="fas fa-chalkboard-teacher me-1"></i>Professeur</th>
                    <th><i class="fas fa-calendar me-1"></i>Date</th>
                    <th><i class="fas fa-info-circle me-1"></i>Statut</th>
                    <th><i class="fas fa-comment me-1"></i>Commentaire</th>
                </tr>
            </thead>
            <tbody>
                @if (ViewBag.Absences != null && ((IEnumerable<Application_Educative.Models.Absence>)ViewBag.Absences).Any())
                {
                    int i = 1;
                    foreach (var abs in ViewBag.Absences)
                    {
                        <tr>
                            <td><span class="badge bg-secondary">@i</span></td>
                            <td><i class="fas fa-book text-success me-1"></i><strong>@abs.Matiere?.Nom</strong></td>
                            <td><span class="badge bg-light text-dark border">@abs.Section?.Nom</span></td>
                            <td><small>@abs.Professeur?.FirstName @abs.Professeur?.LastName</small></td>
                            <td><i class="fas fa-calendar text-muted me-1"></i>@abs.DateAbsence.ToString("dd/MM/yyyy")</td>
                            <td>
                                @if (abs.Justifiee)
                                {
                                    <span class="badge bg-success px-3 py-2">
                                        <i class="fas fa-check me-1"></i>Justifiée
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger px-3 py-2">
                                        <i class="fas fa-times me-1"></i>Non justifiée
                                    </span>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(abs.Commentaire))
                                {
                                    <small class="text-muted">@abs.Commentaire</small>
                                }
                                else
                                {
                                    <small class="text-muted fst-italic">—</small>
                                }
                            </td>
                        </tr>
                        i++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center py-5 text-muted">
                            <i class="fas fa-calendar-check fa-3x mb-3 d-block opacity-25"></i>
                            Aucune absence enregistrée 🎉
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>