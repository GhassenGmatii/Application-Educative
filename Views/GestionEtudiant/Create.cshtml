@model Application_Educative.Models.Etudiant
@{
    ViewData["Title"] = "Ajouter un Étudiant";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<style>
    *, *::before, *::after { box-sizing: border-box; }

    body {
        font-family: 'Plus Jakarta Sans', sans-serif;
        background: #f4f6fb;
        color: #1e2432;
    }

    .page-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: flex-start;
        justify-content: center;
        padding: 40px 16px 60px;
    }

    .form-container {
        width: 100%;
        max-width: 720px;
    }

    .page-title-bar {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 28px;
    }

    .page-title-bar .icon-wrap {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        background: linear-gradient(135deg, #c45000, #ff7a1a);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 20px;
        flex-shrink: 0;
        box-shadow: 0 4px 14px rgba(255,122,26,0.35);
    }

    .page-title-bar h1 {
        font-size: 22px;
        font-weight: 800;
        color: #1e2432;
        margin: 0;
        line-height: 1.2;
    }

    .page-title-bar p {
        font-size: 13px;
        color: #7a8299;
        margin: 2px 0 0;
    }

    .form-card {
        background: white;
        border-radius: 20px;
        box-shadow: 0 2px 20px rgba(0,0,0,0.07);
        overflow: hidden;
        border: 1px solid #eef0f7;
    }

    .section-header {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 22px 28px 0;
        margin-bottom: 20px;
    }

    .section-header .section-icon {
        width: 34px;
        height: 34px;
        border-radius: 10px;
        background: #fff4ec;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #ff7a1a;
        font-size: 15px;
        flex-shrink: 0;
    }

    .section-header h6 {
        font-size: 13px;
        font-weight: 700;
        color: #c45000;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        margin: 0;
    }

    .form-body {
        padding: 0 28px 28px;
    }

    .form-label {
        font-size: 13px;
        font-weight: 600;
        color: #3d4461;
        margin-bottom: 6px;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .form-label i {
        color: #ff7a1a;
        font-size: 12px;
    }

    .form-control,
    .form-select {
        border-radius: 11px;
        border: 1.5px solid #e8eaf2;
        padding: 10px 14px;
        font-size: 14px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        color: #1e2432;
        background-color: #fafbfd;
        transition: border-color 0.2s, box-shadow 0.2s, background-color 0.2s;
    }

    .form-control::placeholder { color: #b0b7cc; }

    .form-control:focus,
    .form-select:focus {
        border-color: #ff7a1a;
        box-shadow: 0 0 0 3px rgba(255,122,26,0.12);
        background-color: #fff;
        outline: none;
    }

    .form-hint {
        font-size: 12px;
        color: #9ea8bf;
        margin-top: 5px;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .section-divider {
        height: 1px;
        background: #f0f2f9;
        margin: 24px 0 0;
    }

    .btn-row {
        display: flex;
        gap: 12px;
        padding: 24px 28px;
        background: #fafbfd;
        border-top: 1px solid #f0f2f9;
    }

    .btn-save {
        flex: 1;
        background: linear-gradient(135deg, #c45000, #ff7a1a);
        color: white;
        border: none;
        border-radius: 11px;
        padding: 12px 20px;
        font-weight: 700;
        font-size: 14px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        cursor: pointer;
        transition: transform 0.15s, box-shadow 0.15s, opacity 0.15s;
        box-shadow: 0 4px 14px rgba(255,122,26,0.3);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .btn-save:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(255,122,26,0.4);
        color: white;
        opacity: 0.95;
    }

    .btn-save:active { transform: translateY(0); }

    .btn-cancel {
        flex: 0 0 auto;
        min-width: 140px;
        border-radius: 11px;
        padding: 12px 20px;
        font-weight: 700;
        font-size: 14px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        border: 1.5px solid #e8eaf2;
        color: #7a8299;
        background: white;
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: all 0.15s;
    }

    .btn-cancel:hover {
        background: #f4f6fb;
        border-color: #d0d3e0;
        color: #3d4461;
    }

    .req { color: #f04438; margin-left: 2px; }

    .input-icon-wrap {
        position: relative;
    }

    .input-icon-wrap .form-control {
        padding-right: 42px;
    }

    .pw-toggle {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        color: #b0b7cc;
        cursor: pointer;
        padding: 0;
        font-size: 14px;
        transition: color 0.2s;
    }

    .pw-toggle:hover { color: #ff7a1a; }

    .fields-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    @@media (max-width: 520px) {
        .fields-row { grid-template-columns: 1fr; }
        .btn-row { flex-direction: column-reverse; }
        .btn-cancel { min-width: unset; }
        .section-header, .form-body { padding-left: 20px; padding-right: 20px; }
        .btn-row { padding: 20px; }
    }
</style>

<div class="page-wrapper">
    <div class="form-container">

        <div class="page-title-bar">
            <div class="icon-wrap">
                <i class="fas fa-user-graduate"></i>
            </div>
            <div>
                <h1>Ajouter un étudiant</h1>
                <p>Remplissez les informations ci-dessous pour créer un nouveau compte</p>
            </div>
        </div>

        <div class="form-card">

            @if (TempData["Success"] != null)
            {
                <div id="triggerSuccess" data-msg="@TempData["Success"]"></div>
            }

            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
            {
                var errors = ViewData.ModelState.Values
                    .SelectMany(v => v.Errors)
                    .Select(e => e.ErrorMessage)
                    .ToList();
                <div id="triggerError" data-msg="@string.Join("|", errors)"></div>
            }

            <form method="post" action="/GestionEtudiant/Create">
                @Html.AntiForgeryToken()

                <div class="section-header">
                    <div class="section-icon"><i class="fas fa-id-card"></i></div>
                    <h6>Informations personnelles</h6>
                </div>

                <div class="form-body">

                    <div class="fields-row mb-3">
                        <div>
                            <label class="form-label">
                                <i class="fas fa-user"></i> Prénom <span class="req">*</span>
                            </label>
                            <input type="text" name="Prenom" class="form-control" placeholder="Ex: Mohamed" required />
                        </div>
                        <div>
                            <label class="form-label">
                                <i class="fas fa-user"></i> Nom <span class="req">*</span>
                            </label>
                            <input type="text" name="Nom" class="form-control" placeholder="Ex: Ben Ali" required />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">
                            <i class="fas fa-envelope"></i> Email <span class="req">*</span>
                        </label>
                        <input type="email" name="Email" class="form-control" placeholder="etudiant@ecole.tn" required />
                        <div class="form-hint"><i class="fas fa-circle-info"></i> Utilisé pour la connexion</div>
                    </div>

                    <div class="fields-row">
                        <div class="mb-3">
                            <label class="form-label">
                                <i class="fas fa-lock"></i> Mot de passe <span class="req">*</span>
                            </label>
                            <div class="input-icon-wrap">
                                <input type="password" id="pw1" name="MotDePasse" class="form-control" placeholder="Minimum 6 caractères" required />
                                <button type="button" class="pw-toggle" onclick="togglePw('pw1',this)">
                                    <i class="fas fa-eye"></i>
                                </button>
                            </div>
                        </div>
                        <div class="mb-0">
                            <label class="form-label">
                                <i class="fas fa-lock"></i> Confirmer le mot de passe <span class="req">*</span>
                            </label>
                            <div class="input-icon-wrap">
                                <input type="password" id="pw2" name="ConfirmPassword" class="form-control" placeholder="Répétez le mot de passe" required />
                                <button type="button" class="pw-toggle" onclick="togglePw('pw2',this)">
                                    <i class="fas fa-eye"></i>
                                </button>
                            </div>
                        </div>
                    </div>

                </div>

                <div class="section-divider"></div>

                <div class="section-header" style="margin-top:24px;">
                    <div class="section-icon"><i class="fas fa-graduation-cap"></i></div>
                    <h6>Informations académiques</h6>
                </div>

                <div class="form-body">

                    <div class="mb-3">
                        <label class="form-label">
                            <i class="fas fa-layer-group"></i> Section <span class="req">*</span>
                        </label>
                        <select name="Section" id="sectionSelect" class="form-select" required onchange="updateSpecialites()">
                            <option value="">— Choisir une section —</option>
                            <optgroup label="🎓 Cycle Ingénieur">
                                <option value="1ère Année Cycle Ing">1ère Année Cycle Ing</option>
                                <option value="1ère Année Cycle Ing Alternant">1ère Année Cycle Ing Alternant</option>
                                <option value="2ème Année Cycle Ing">2ème Année Cycle Ing</option>
                                <option value="2ème Année Cycle Ing Alternant">2ème Année Cycle Ing Alternant</option>
                                <option value="3ème Année Cycle Ing">3ème Année Cycle Ing</option>
                                <option value="3ème Année Cycle Ing Alternant">3ème Année Cycle Ing Alternant</option>
                            </optgroup>
                            <optgroup label="📘 Licence">
                                <option value="1ère Année Licence">1ère Année Licence</option>
                                <option value="2ème Année Licence">2ème Année Licence</option>
                                <option value="3ème Année Licence">3ème Année Licence</option>
                            </optgroup>
                            <optgroup label="🎓 Master">
                                <option value="1ère Année Master">1ère Année Master</option>
                                <option value="2ème Année Master">2ème Année Master</option>
                            </optgroup>
                        </select>
                    </div>

                    <div class="fields-row">
                        <div class="mb-0">
                            <label class="form-label">
                                <i class="fas fa-tag"></i> Spécialité <span class="req">*</span>
                            </label>
                            <select name="Specialite" id="specialiteSelect" class="form-select" required>
                                <option value="">— Choisir une section d'abord —</option>
                            </select>
                            <div class="form-hint" id="specHint">
                                <i class="fas fa-circle-info"></i> Les spécialités s'affichent selon la section choisie
                            </div>
                        </div>
                        <div class="mb-0">
                            <label class="form-label">
                                <i class="fas fa-circle-dot"></i> État <span class="req">*</span>
                            </label>
                            <select name="Etat" class="form-select" required>
                                <option value="">— Choisir —</option>
                                <option>Admis</option>
                                <option>Redoublant</option>
                            </select>
                        </div>
                    </div>

                </div>

                <div class="btn-row">
                    <a href="/GestionEtudiant/Index" class="btn-cancel">
                        <i class="fas fa-arrow-left"></i> Annuler
                    </a>
                    <button type="submit" class="btn-save">
                        <i class="fas fa-user-plus"></i> Enregistrer l'étudiant
                    </button>
                </div>

            </form>
        </div>

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    function togglePw(id, btn) {
        const input = document.getElementById(id);
        const icon  = btn.querySelector('i');
        if (input.type === 'password') {
            input.type = 'text';
            icon.classList.replace('fa-eye', 'fa-eye-slash');
        } else {
            input.type = 'password';
            icon.classList.replace('fa-eye-slash', 'fa-eye');
        }
    }

    const successEl = document.getElementById("triggerSuccess");
    if (successEl) {
        Swal.fire({
            icon: "success",
            title: "Étudiant ajouté !",
            text: successEl.dataset.msg || "L'étudiant a été enregistré avec succès.",
            confirmButtonText: "Voir la liste",
            cancelButtonText: "Ajouter un autre",
            showCancelButton: true,
            confirmButtonColor: "#ff7a1a",
            cancelButtonColor: "#6c757d",
            background: "#fff",
            iconColor: "#ff7a1a",
            timer: 8000,
            timerProgressBar: true
        }).then((result) => {
            if (result.isConfirmed) window.location.href = "/GestionEtudiant/Index";
        });
    }

    const errorEl = document.getElementById("triggerError");
    if (errorEl) {
        const msgs    = errorEl.dataset.msg.split("|").filter(m => m.trim() !== "");
        const htmlList = "<ul style='text-align:left;margin-top:10px'>"
            + msgs.map(m => `<li>${m}</li>`).join("") + "</ul>";
        Swal.fire({
            icon: "error",
            title: "Erreur de saisie",
            html: "Veuillez corriger les erreurs suivantes :" + htmlList,
            confirmButtonText: "Corriger",
            confirmButtonColor: "#e53935",
            background: "#fff",
            iconColor: "#e53935"
        });
    }

    document.querySelector("form").addEventListener("submit", function (e) {
        const prenom = document.querySelector("[name='Prenom']").value.trim();
        const nom    = document.querySelector("[name='Nom']").value.trim();
        if (!prenom || !nom) return;

        e.preventDefault();
        const formRef = this;
        Swal.fire({
            icon: "question",
            title: "Confirmer l'ajout",
            html: `Voulez-vous ajouter l'étudiant <br><strong>${prenom} ${nom}</strong> ?`,
            confirmButtonText: '<i class="fas fa-check"></i> Oui, ajouter',
            cancelButtonText: '<i class="fas fa-times"></i> Annuler',
            showCancelButton: true,
            confirmButtonColor: "#ff7a1a",
            cancelButtonColor: "#6c757d",
            background: "#fff",
            iconColor: "#ff7a1a"
        }).then((result) => {
            if (result.isConfirmed) formRef.submit();
        });
    });

    const specialitesMap = {
        "1ère Année Cycle Ing":           ["Tronc commun"],
        "1ère Année Cycle Ing Alternant": ["Tronc commun Alternant"],
        "2ème Année Cycle Ing":           ["GL","DevOps","BI","Réseaux","Sécurité","Cloud Computing"],
        "2ème Année Cycle Ing Alternant": ["GL","DevOps","BI","Réseaux","Sécurité","Cloud Computing"],
        "3ème Année Cycle Ing":           ["GL","DevOps","BI","Réseaux","Sécurité","Cloud Computing","Intelligence Artificielle"],
        "3ème Année Cycle Ing Alternant": ["GL","DevOps","BI","Réseaux","Sécurité","Cloud Computing","Intelligence Artificielle"],
        "1ère Année Licence": ["Informatique","Gestion","Mathématiques"],
        "2ème Année Licence": ["Informatique","Gestion","Mathématiques","Économie"],
        "3ème Année Licence": ["Informatique","Gestion","Mathématiques","Économie","Comptabilité"],
        "1ère Année Master":  ["Informatique","Finance","Marketing","Management","Comptabilité","Commerce International","Droit des Affaires","Ressources Humaines","Intelligence Artificielle","Cybersécurité"],
        "2ème Année Master":  ["Informatique","Finance","Marketing","Management","Comptabilité","Commerce International","Droit des Affaires","Ressources Humaines","Intelligence Artificielle","Cybersécurité"]
    };

    function updateSpecialites() {
        const section          = document.getElementById("sectionSelect").value;
        const specialiteSelect = document.getElementById("specialiteSelect");
        const hint             = document.getElementById("specHint");
        specialiteSelect.innerHTML = '<option value="">— Choisir une spécialité —</option>';
        if (section && specialitesMap[section]) {
            specialitesMap[section].forEach(function (spec) {
                const opt       = document.createElement("option");
                opt.value       = spec;
                opt.textContent = spec;
                specialiteSelect.appendChild(opt);
            });
            hint.innerHTML = `<i class="fas fa-check-circle" style="color:#ff7a1a"></i> ${specialitesMap[section].length} spécialité(s) disponible(s)`;
        } else {
            hint.innerHTML = '<i class="fas fa-circle-info"></i> Les spécialités s\'affichent selon la section choisie';
        }
    }
</script>
