@model Application_Educative.Models.Admin
@{
    ViewData["Title"] = "Confirmer la Suppression";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    body { background-color: #f4f6f9; }
    .delete-card {
        border-radius: 16px;
        box-shadow: 0 8px 30px rgba(0,0,0,0.12);
        overflow: hidden;
        max-width: 500px;
        margin: 40px auto;
    }
    .delete-header {
        background: linear-gradient(135deg, #dc3545, #7b0d1e);
        color: white;
        padding: 30px;
        text-align: center;
    }
    .delete-body { padding: 35px; background: white; }
    .info-row {
        display: flex;
        justify-content: space-between;
        padding: 10px 0;
        border-bottom: 1px solid #f0f0f0;
    }
    .info-label { color: #888; font-weight: 500; }
    .info-value { font-weight: 600; color: #333; }
    .btn-confirm {
        background: linear-gradient(135deg, #dc3545, #7b0d1e);
        color: white;
        border: none;
        border-radius: 10px;
        padding: 12px 30px;
        font-weight: 600;
        width: 100%;
        font-size: 16px;
        transition: all 0.2s;
    }
    .btn-confirm:hover { transform: translateY(-2px); box-shadow: 0 5px 15px rgba(220,53,69,0.4); color: white; }
    .btn-cancel {
        border-radius: 10px;
        padding: 12px 30px;
        font-weight: 600;
        width: 100%;
        font-size: 16px;
    }
</style>

<div class="container">
    <div class="delete-card">
        <div class="delete-header">
            <i class="fas fa-exclamation-triangle fa-3x mb-2"></i>
            <h3 class="mb-0">Confirmer la Suppression</h3>
            <p class="mb-0 opacity-75 mt-1">Cette action est irréversible</p>
        </div>
        <div class="delete-body">

            <div class="alert alert-danger mb-4">
                <i class="fas fa-skull-crossbones me-2"></i>
                Vous êtes sur le point de <strong>supprimer définitivement</strong> cet administrateur.
            </div>

            <div class="mb-4">
                <div class="info-row">
                    <span class="info-label"><i class="fas fa-envelope me-1"></i>Email</span>
                    <span class="info-value">@Model.Username</span>
                </div>
                <div class="info-row">
                    <span class="info-label"><i class="fas fa-user me-1"></i>Prénom</span>
                    <span class="info-value">@(Model.FirstName ?? "—")</span>
                </div>
                <div class="info-row">
                    <span class="info-label"><i class="fas fa-user me-1"></i>Nom</span>
                    <span class="info-value">@(Model.LastName ?? "—")</span>
                </div>
                <div class="info-row">
                    <span class="info-label"><i class="fas fa-calendar me-1"></i>Date d'ajout</span>
                    <span class="info-value">@Model.DateAjout.ToString("dd/MM/yyyy")</span>
                </div>
            </div>

            <form method="post" action="/GestionAdmin/Delete/@Model.Id">
                @Html.AntiForgeryToken()
                <div class="d-flex gap-3">
                    <a href="/GestionAdmin/Index" class="btn btn-outline-secondary btn-cancel">
                        <i class="fas fa-times me-1"></i>Annuler
                    </a>
                    <button type="submit" class="btn btn-confirm">
                        <i class="fas fa-trash me-1"></i>Oui, Supprimer
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>