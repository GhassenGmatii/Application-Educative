@model Application_Educative.Models.Admin
@{
    ViewData["Title"] = "Modifier Administrateur";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    body { background-color: #f4f6f9; }
    .edit-card {
        border-radius: 16px;
        box-shadow: 0 8px 30px rgba(0,0,0,0.12);
        overflow: hidden;
        max-width: 550px;
        margin: 40px auto;
    }
    .edit-header {
        background: linear-gradient(135deg, #ffc107, #e65c00);
        color: white;
        padding: 30px;
        text-align: center;
    }
    .edit-body { padding: 35px; background: white; }
    .form-label { font-weight: 600; color: #444; }
    .form-control {
        border-radius: 10px;
        border: 2px solid #dee2e6;
        padding: 12px 15px;
    }
    .form-control:focus { border-color: #ffc107; box-shadow: 0 0 0 0.2rem rgba(255,193,7,0.2); }
    .btn-save {
        background: linear-gradient(135deg, #ffc107, #e65c00);
        color: white;
        border: none;
        border-radius: 10px;
        padding: 12px 30px;
        font-weight: 600;
        width: 100%;
        font-size: 16px;
        transition: all 0.2s;
    }
    .btn-save:hover { transform: translateY(-2px); box-shadow: 0 5px 15px rgba(255,193,7,0.4); color: white; }
    .btn-cancel {
        border-radius: 10px;
        padding: 12px 30px;
        font-weight: 600;
        width: 100%;
        font-size: 16px;
    }
</style>

<div class="container">
    <div class="edit-card">
        <div class="edit-header">
            <i class="fas fa-user-edit fa-3x mb-2"></i>
            <h3 class="mb-0">Modifier Administrateur</h3>
            <p class="mb-0 opacity-75 mt-1">@Model.Username</p>
        </div>
        <div class="edit-body">

            <div class="alert alert-info mb-4">
                <i class="fas fa-info-circle me-2"></i>
                Laissez le <strong>mot de passe vide</strong> si vous ne souhaitez pas le modifier.
            </div>

            <form method="post" action="/GestionAdmin/Edit/@Model.Id">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" value="@Model.Id" />
                <input type="hidden" name="EstActif" value="@Model.EstActif" />
                <input type="hidden" name="DateAjout" value="@Model.DateAjout.ToString("o")" />

                <div class="mb-3">
                    <label class="form-label">
                        <i class="fas fa-envelope me-1 text-warning"></i>Email
                    </label>
                    <input type="email" name="Username" value="@Model.Username"
                           class="form-control" placeholder="Email de l'administrateur" />
                </div>

                <div class="mb-3">
                    <label class="form-label">
                        <i class="fas fa-user me-1 text-warning"></i>Prénom
                    </label>
                    <input type="text" name="FirstName" value="@Model.FirstName"
                           class="form-control" placeholder="Prénom de l'administrateur" />
                </div>

                <div class="mb-3">
                    <label class="form-label">
                        <i class="fas fa-user me-1 text-warning"></i>Nom
                    </label>
                    <input type="text" name="LastName" value="@Model.LastName"
                           class="form-control" placeholder="Nom de l'administrateur" />
                </div>

                <div class="mb-4">
                    <label class="form-label">
                        <i class="fas fa-lock me-1 text-warning"></i>Nouveau mot de passe
                    </label>
                    <input type="password" name="Password"
                           class="form-control" placeholder="Laisser vide = pas de changement" />
                </div>

                <div class="d-flex gap-3">
                    <a href="/GestionAdmin/Index" class="btn btn-outline-secondary btn-cancel">
                        <i class="fas fa-arrow-left me-1"></i>Annuler
                    </a>
                    <button type="submit" class="btn btn-save" id="btnSave">
                        <i class="fas fa-save me-1"></i>Enregistrer
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal confirmation style Facebook -->
<div class="modal fade" id="confirmModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:16px; overflow:hidden;">
            <div class="modal-header border-0" style="background: linear-gradient(135deg, #ffc107, #e65c00);">
                <h5 class="modal-title text-white">
                    <i class="fas fa-question-circle me-2"></i>Confirmer la modification
                </h5>
            </div>
            <div class="modal-body text-center py-4">
                <i class="fas fa-user-edit fa-3x text-warning mb-3"></i>
                <p class="fs-5 fw-bold">Voulez-vous enregistrer les modifications ?</p>
                <p class="text-muted">Les informations de l'administrateur seront mises à jour.</p>
            </div>
            <div class="modal-footer border-0 justify-content-center gap-3 pb-4">
                <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">
                    <i class="fas fa-times me-1"></i>Annuler
                </button>
                <button type="button" class="btn text-white px-4" id="btnConfirm"
                        style="background: linear-gradient(135deg, #ffc107, #e65c00);">
                    <i class="fas fa-check me-1"></i>Oui, enregistrer
                </button>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    document.getElementById('btnSave').addEventListener('click', function (e) {
        e.preventDefault();
        new bootstrap.Modal(document.getElementById('confirmModal')).show();
    });

    document.getElementById('btnConfirm').addEventListener('click', function () {
        document.querySelector('form').submit();
    });
</script>