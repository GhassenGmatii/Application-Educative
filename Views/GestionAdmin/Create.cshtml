@model Application_Educative.Models.Admin
@{
    ViewData["Title"] = "Ajouter un Administrateur";
}

<!-- Bootstrap CSS & Font Awesome -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    .page-header {
        background: linear-gradient(135deg, #f97316 0%, #c2410c 100%); /* Orange */
        color: white;
        padding: 40px 0;
        margin-bottom: 30px;
        border-radius: 0 0 50px 50px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

    .form-card {
        border: none;
        border-radius: 20px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.08);
        overflow: hidden;
        transition: transform 0.3s ease;
    }

        .form-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 30px 60px rgba(0,0,0,0.12);
        }

    .card-header-custom {
        background: linear-gradient(135deg, #f97316 0%, #c2410c 100%); /* Orange */
        color: white;
        padding: 25px;
        border: none;
    }

        .card-header-custom h4 {
            margin: 0;
            font-weight: 600;
            font-size: 1.5rem;
        }

        .card-header-custom p {
            margin: 10px 0 0 0;
            opacity: 0.9;
            font-size: 0.95rem;
        }

    .form-body {
        padding: 40px;
        background: white;
    }

    .form-group {
        margin-bottom: 25px;
    }

    .form-label {
        font-weight: 600;
        color: #2d3748;
        margin-bottom: 8px;
        font-size: 0.95rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .input-group-custom {
        position: relative;
    }

    .input-icon {
        position: absolute;
        left: 15px;
        top: 50%;
        transform: translateY(-50%);
        color: #f97316; /* Orange */
        z-index: 10;
    }

    .form-control-custom {
        width: 100%;
        padding: 15px 15px 15px 45px;
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        font-size: 1rem;
        transition: all 0.3s ease;
        background: #f8fafc;
    }

        .form-control-custom:focus {
            border-color: #f97316; /* Orange */
            box-shadow: 0 0 0 3px rgba(249, 115, 22, 0.1);
            outline: none;
            background: white;
        }

        .form-control-custom:hover {
            border-color: #c2410c; /* Orange foncé */
        }

    .btn-create {
        background: linear-gradient(135deg, #f97316 0%, #c2410c 100%); /* Orange */
        color: white;
        border: none;
        padding: 15px 40px;
        border-radius: 12px;
        font-weight: 600;
        font-size: 1.1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        text-transform: uppercase;
        letter-spacing: 1px;
        box-shadow: 0 10px 20px rgba(249, 115, 22, 0.3);
    }

        .btn-create:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 30px rgba(249, 115, 22, 0.4);
        }

        .btn-create:active {
            transform: translateY(0);
        }

    .btn-back {
        background: white;
        color: #4a5568;
        border: 2px solid #e2e8f0;
        padding: 15px 30px;
        border-radius: 12px;
        font-weight: 600;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
        margin-left: 15px;
    }

        .btn-back:hover {
            background: #f7fafc;
            border-color: #cbd5e0;
            color: #2d3748;
            transform: translateY(-2px);
        }

    .alert-custom {
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 30px;
        border: none;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    }

        .alert-custom ul {
            margin: 10px 0 0 0;
            padding-left: 20px;
        }

        .alert-custom li {
            margin-bottom: 5px;
        }

    .password-requirements {
        background: #f8fafc;
        border-radius: 12px;
        padding: 15px;
        margin-top: 15px;
        border: 1px solid #e2e8f0;
    }

        .password-requirements h6 {
            color: #4a5568;
            font-weight: 600;
            margin-bottom: 10px;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .password-requirements ul {
            margin: 0;
            padding-left: 20px;
            color: #718096;
            font-size: 0.9rem;
        }

        .password-requirements li {
            margin-bottom: 5px;
        }
</style>

<div class="page-header">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h1><i class="fas fa-user-shield me-3"></i>Espace Administrateur</h1>
                <p class="lead mb-0">Créez un nouveau compte administrateur avec des droits d'accès complets</p>
            </div>
            <div class="col-md-4 text-end">
                <i class="fas fa-user-plus fa-4x opacity-50"></i>
            </div>
        </div>
    </div>
</div>

<div class="container mb-5">
    <!-- Affiche les erreurs -->
    @if (ViewData.ModelState.ErrorCount > 0)
    {
        <div class="alert alert-danger alert-custom">
            <i class="fas fa-exclamation-triangle me-2"></i>
            <strong>Erreur de validation</strong>
            <ul>
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@error.ErrorMessage</li>
                }
            </ul>
        </div>
    }

    <!-- Message de succès -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-custom">
            <i class="fas fa-check-circle me-2"></i>
            @TempData["SuccessMessage"]
        </div>
    }

    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="form-card">
                <div class="card-header-custom">
                    <h4><i class="fas fa-edit me-2"></i>Nouvel Administrateur</h4>
                    <p>Remplissez les informations ci-dessous pour créer un nouveau compte</p>
                </div>
                
                <div class="form-body">
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()

                        <div class="form-group">
                            <label class="form-label">
                                <i class="fas fa-envelope me-2"></i>Adresse email
                            </label>
                            <div class="input-group-custom">
                                <i class="fas fa-envelope input-icon"></i>
                                <input asp-for="Username" name="Username" class="form-control-custom" 
                                       placeholder="exemple@domaine.com" value="" />
                            </div>
                            <small class="text-muted mt-2 d-block">
                                <i class="fas fa-info-circle me-1"></i>
                                L'email sera utilisé pour la connexion
                            </small>
                        </div>

                        <div class="form-group">
                            <label class="form-label">
                                <i class="fas fa-lock me-2"></i>Mot de passe
                            </label>
                            <div class="input-group-custom">
                                <i class="fas fa-lock input-icon"></i>
                                <input asp-for="Password" name="Password" type="password" class="form-control-custom" 
                                       placeholder="••••••••" />
                            </div>
                            
                            <!-- Exigences du mot de passe -->
                            <div class="password-requirements">
                                <h6><i class="fas fa-shield-alt me-2"></i>Exigences de sécurité</h6>
                                <ul>
                                    <li><i class="fas fa-check-circle text-success me-2"></i> Minimum 8 caractères</li>
                                    <li><i class="fas fa-check-circle text-success me-2"></i> Au moins une lettre minuscule</li>
                                    <li><i class="fas fa-check-circle text-success me-2"></i> Au moins une lettre majuscule</li>
                                    <li><i class="fas fa-check-circle text-success me-2"></i> Au moins un chiffre</li>
                                    <li><i class="fas fa-check-circle text-success me-2"></i> Au moins un symbole (&#64;$!%*?&)</li>
                                </ul>
                            </div>
                        </div>

                        <div class="text-center mt-5">
                            <button type="submit" class="btn-create">
                                <i class="fas fa-save me-2"></i>Créer l'administrateur
                            </button>
                           
                        </div>
                    </form>
                </div>
            </div>

            <!-- Carte d'information supplémentaire -->
            <div class="row mt-4">
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm rounded-4">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-primary bg-opacity-10 rounded-circle p-3 me-3">
                                    <i class="fas fa-shield-alt text-primary fa-2x"></i>
                                </div>
                                <div>
                                    <h6 class="fw-bold mb-1">Sécurité</h6>
                                    <p class="text-muted small mb-0">Tous les comptes sont protégés</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm rounded-4">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-success bg-opacity-10 rounded-circle p-3 me-3">
                                    <i class="fas fa-clock text-success fa-2x"></i>
                                </div>
                                <div>
                                    <h6 class="fw-bold mb-1">Accès immédiat</h6>
                                    <p class="text-muted small mb-0">Compte actif après création</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>