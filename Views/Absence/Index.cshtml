@model IEnumerable<Application_Educative.Models.Absence>
@{
    ViewData["Title"] = "Gestion des Absences";
    string role = ViewBag.Role ?? "Admin";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    .page-header { background: linear-gradient(135deg, #6f42c1, #4e2d8a); color: white; padding: 25px 30px; border-radius: 14px; margin-bottom: 25px; }
    .stat-card { border-radius: 12px; padding: 20px; color: white; box-shadow: 0 4px 15px rgba(0,0,0,0.15); }
    .stat-card.purple { background: linear-gradient(135deg, #6f42c1, #4e2d8a); }
    .stat-card.red { background: linear-gradient(135deg, #dc3545, #b02a37); }
    .stat-card.green { background: linear-gradient(135deg, #28a745, #1e7e34); }
    .card-table { border-radius: 14px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); overflow: hidden; }
    .table thead th { background: #6f42c1; color: white; border: none; padding: 14px 16px; font-weight: 600; }
    .table tbody tr:hover { background-color: #f5f0ff; transition: 0.2s; }
    .table tbody td { padding: 13px 16px; vertical-align: middle; }
    .btn-justify { background: linear-gradient(135deg, #28a745, #1e7e34); color: white; border: none; border-radius: 7px; padding: 5px 12px; font-size: 12px; font-weight: 600; transition: all 0.2s; }
    .btn-unjustify { background: linear-gradient(135deg, #fd7e14, #e65c00); color: white; border: none; border-radius: 7px; padding: 5px 12px; font-size: 12px; font-weight: 600; transition: all 0.2s; }
    .btn-delete { background: linear-gradient(135deg, #dc3545, #b02a37); color: white; border: none; border-radius: 7px; padding: 5px 12px; font-size: 12px; font-weight: 600; transition: all 0.2s; }
    .btn-new { background: linear-gradient(135deg, #6f42c1, #4e2d8a); color: white; border: none; border-radius: 10px; padding: 10px 22px; font-weight: 600; transition: all 0.2s; }
    .btn-new:hover { transform: translateY(-2px); color: white; }
</style>

<div class="container-fluid py-4">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Header -->
    <div class="page-header d-flex justify-content-between align-items-center">
        <div>
            <h2><i class="fas fa-calendar-times me-2"></i>Gestion des Absences</h2>
            <p class="mb-0 opacity-75">
                @if (role == "Etudiant") { <text>Vos absences</text> }
                else if (role == "Professeur") { <text>Absences que vous avez saisies</text> }
                else { <text>Toutes les absences de la plateforme</text> }
            </p>
        </div>
        @if (role != "Etudiant")
        {
            <a href="/Absence/Create" class="btn btn-new">
                <i class="fas fa-plus me-2"></i>Saisir une absence
            </a>
        }
    </div>

    <!-- Stats -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="stat-card purple">
                <div class="d-flex justify-content-between align-items-center">
                    <div><p class="mb-1 opacity-75">Total absences</p><h3 class="mb-0 fw-bold">@Model.Count()</h3></div>
                    <i class="fas fa-calendar-times fa-2x opacity-75"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card red">
                <div class="d-flex justify-content-between align-items-center">
                    <div><p class="mb-1 opacity-75">Non justifiées</p><h3 class="mb-0 fw-bold">@Model.Count(a => !a.Justifiee)</h3></div>
                    <i class="fas fa-times-circle fa-2x opacity-75"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card green">
                <div class="d-flex justify-content-between align-items-center">
                    <div><p class="mb-1 opacity-75">Justifiées</p><h3 class="mb-0 fw-bold">@Model.Count(a => a.Justifiee)</h3></div>
                    <i class="fas fa-check-circle fa-2x opacity-75"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Tableau -->
    <div class="card card-table">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th><i class="fas fa-user me-1"></i>Étudiant</th>
                    <th><i class="fas fa-book me-1"></i>Matière</th>
                    <th><i class="fas fa-layer-group me-1"></i>Section</th>
                    @if (role != "Etudiant")
                    {
                        <th><i class="fas fa-chalkboard-teacher me-1"></i>Saisi par</th>
                    }
                    <th><i class="fas fa-calendar me-1"></i>Date</th>
                    <th><i class="fas fa-info-circle me-1"></i>Statut</th>
                    @if (role != "Etudiant")
                    {
                        <th class="text-center">Actions</th>
                    }
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center py-5 text-muted">
                            <i class="fas fa-calendar-check fa-3x mb-3 d-block opacity-25"></i>
                            Aucune absence trouvée
                        </td>
                    </tr>
                }
                else
                {
                    int i = 1;
                    foreach (var abs in Model)
                    {
                        <tr>
                            <td><span class="badge bg-secondary">@i</span></td>
                            <td>
                                <strong>@abs.Etudiant?.Prenom @abs.Etudiant?.Nom</strong><br>
                                <small class="text-muted">@abs.Etudiant?.Section</small>
                            </td>
                            <td><i class="fas fa-book text-purple me-1"></i>@abs.Matiere?.Nom</td>
                            <td><span class="badge bg-light text-dark border">@abs.Section?.Nom</span></td>
                            @if (role != "Etudiant")
                            {
                                <td><small>@abs.Professeur?.FirstName @abs.Professeur?.LastName</small></td>
                            }
                            <td>
                                <i class="fas fa-calendar text-muted me-1"></i>
                                @abs.DateAbsence.ToString("dd/MM/yyyy")
                            </td>
                            <td>
                                @if (abs.Justifiee)
                                {
                                    <span class="badge bg-success px-3 py-2">
                                        <i class="fas fa-check me-1"></i>Justifiée
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger px-3 py-2">
                                        <i class="fas fa-times me-1"></i>Non justifiée
                                    </span>
                                }
                            </td>
                            @if (role != "Etudiant")
                            {
                                <td class="text-center">
                                    <div class="d-flex gap-1 justify-content-center">
                                        <form method="post" action="/Absence/ToggleJustification" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@abs.Id" />
                                            <button type="submit" class="@(abs.Justifiee ? "btn-unjustify" : "btn-justify") btn">
                                                <i class="fas @(abs.Justifiee ? "fa-times" : "fa-check") me-1"></i>
                                                @(abs.Justifiee ? "Annuler" : "Justifier")
                                            </button>
                                        </form>
                                        @if (role == "Admin")
                                        {
                                            <form method="post" action="/Absence/Delete/@abs.Id" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-delete"
                                                        onclick="return confirm('Supprimer cette absence ?')">
                                                    <i class="fas fa-trash-can"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            }
                        </tr>
                        i++;
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    setTimeout(() => {
        document.querySelectorAll('.alert').forEach(a => new bootstrap.Alert(a).close());
    }, 4000);
</script>