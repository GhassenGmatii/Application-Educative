@model List<string>

@{
    ViewData["Title"] = "Gestion Étudiants";
}

<div class="container mt-5">
    <h2>Gestion Étudiants</h2>
    
    @if (Model == null || Model.Count == 0)
    {
        <p>Aucune section disponible</p>
    }
    else
    {
        <ul class="list-group">
        @foreach (var s in Model)
        {
            <li class="list-group-item">@s</li>
        }
        </ul>
    }
</div>
