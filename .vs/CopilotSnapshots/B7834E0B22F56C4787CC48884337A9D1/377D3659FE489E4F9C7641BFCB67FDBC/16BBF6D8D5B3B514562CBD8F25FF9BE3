<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>@ViewData["Title"] - Application Éducative</title>
    <link href="~/vendor/fontawesome-free/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css?family=Nunito:200,300,400,600,700,800,900" rel="stylesheet">
    <link href="~/css/sb-admin-2.min.css" rel="stylesheet">
</head>

<body id="page-top">
<div id="wrapper">

    <!-- SIDEBAR -->
    <ul class="navbar-nav bg-gradient-primary sidebar sidebar-dark accordion" id="accordionSidebar">

        <a class="sidebar-brand d-flex align-items-center justify-content-center" href="/Home/Index">
            <div class="sidebar-brand-icon rotate-n-15">
                <i class="fas fa-graduation-cap"></i>
            </div>
            <div class="sidebar-brand-text mx-3">APPRENTI INSTRUIT</div>
        </a>

        <hr class="sidebar-divider my-0">

        <!-- Dashboard -->
        <li class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
            <a class="nav-link" href="/Home/Index">
                <i class="fas fa-fw fa-tachometer-alt"></i>
                <span>Tableau de bord</span>
            </a>
        </li>

        <hr class="sidebar-divider">
        <div class="sidebar-heading">Administration</div>

        <!-- Gestion Admin -->
        @{
            bool isAdmin = ViewContext.RouteData.Values["controller"]?.ToString() == "GestionAdmin";
        }
        <li class="nav-item">
            <a class="nav-link @(!isAdmin ? "collapsed" : "")" href="#collapseAdmin"
               data-bs-toggle="collapse"
               aria-expanded="@(isAdmin ? "true" : "false")">
                <i class="fas fa-fw fa-user-shield"></i>
                <span>Gestion Administrateur</span>
            </a>
            <div id="collapseAdmin" class="collapse @(isAdmin ? "show" : "")">
                <div class="bg-white py-2 collapse-inner rounded">
                    <h6 class="collapse-header">Administrateurs :</h6>
                    <a class="collapse-item" href="/GestionAdmin/Create">
                        <i class="fas fa-user-plus mr-1 text-success"></i> Ajouter
                    </a>
                    <a class="collapse-item" href="/GestionAdmin/Index">
                        <i class="fas fa-list mr-1 text-primary"></i> Liste
                    </a>
                </div>
            </div>
        </li>

        <hr class="sidebar-divider">
        <div class="sidebar-heading">Enseignement</div>

        <!-- Gestion Professeur -->
        @{
            bool isProf = ViewContext.RouteData.Values["controller"]?.ToString() == "GestionProfesseur";
        }
        <li class="nav-item">
            <a class="nav-link @(!isProf ? "collapsed" : "")" href="#collapseProf"
               data-bs-toggle="collapse"
               aria-expanded="@(isProf ? "true" : "false")">
                <i class="fas fa-fw fa-chalkboard-teacher"></i>
                <span>Gestion Professeur</span>
            </a>
            <div id="collapseProf" class="collapse @(isProf ? "show" : "")">
                <div class="bg-white py-2 collapse-inner rounded">
                    <h6 class="collapse-header">Professeurs :</h6>
                    <a class="collapse-item" href="/GestionProfesseur/Create">
                        <i class="fas fa-user-plus mr-1 text-success"></i> Ajouter
                    </a>
                    <a class="collapse-item" href="/GestionProfesseur/Index">
                        <i class="fas fa-list mr-1 text-primary"></i> Liste
                    </a>
                </div>
            </div>
        </li>

        <!-- Gestion Étudiant -->
        @{
            bool isEtudiant = ViewContext.RouteData.Values["controller"]?.ToString() == "GestionEtudiant";
        }
        <li class="nav-item">
            <a class="nav-link @(!isEtudiant ? "collapsed" : "")" href="#collapseEtudiant"
               data-bs-toggle="collapse"
               aria-expanded="@(isEtudiant ? "true" : "false")">
                <i class="fas fa-fw fa-user-graduate"></i>
                <span>Gestion Étudiant</span>
            </a>
            <div id="collapseEtudiant" class="collapse @(isEtudiant ? "show" : "")">
                <div class="bg-white py-2 collapse-inner rounded">
                    <h6 class="collapse-header">Étudiants :</h6>
                    <a class="collapse-item" href="/GestionEtudiant/Create">
                        <i class="fas fa-user-plus mr-1 text-success"></i> Ajouter
                    </a>
                    <a class="collapse-item" href="/GestionEtudiant/Index">
                        <i class="fas fa-list mr-1 text-primary"></i> Liste
                    </a>
                </div>
            </div>
        </li>

        <hr class="sidebar-divider">
        <div class="sidebar-heading">Absences</div>

        <li class="nav-item">
            <a class="nav-link" href="#">
                <i class="fas fa-fw fa-calendar-times"></i>
                <span>Absences</span>
            </a>
        </li>

        <li class="nav-item">
            <a class="nav-link" href="#">
                <i class="fas fa-fw fa-bell"></i>
                <span>Notifications</span>
            </a>
        </li>

        <hr class="sidebar-divider d-none d-md-block">

    </ul>
    <!-- END SIDEBAR -->

    <!-- CONTENT -->
    <div id="content-wrapper" class="d-flex flex-column">
        <div id="content">

            <!-- TOPBAR -->
            <nav class="navbar navbar-expand navbar-light bg-white topbar mb-4 shadow">
                <button id="sidebarToggleTop" class="btn btn-link d-md-none rounded-circle mr-3">
                    <i class="fa fa-bars"></i>
                </button>
                <ul class="navbar-nav ml-auto">
                    <li class="nav-item">
                        <span class="mr-2 text-gray-600 small">
                            <i class="fas fa-user-circle mr-1"></i>
                            @(User.Identity?.Name ?? "Admin")
                        </span>
                    </li>
                </ul>
            </nav>

            <div class="container-fluid">
                @RenderBody()
            </div>
        </div>

        <footer class="sticky-footer bg-white">
            <div class="container my-auto text-center">
                <span>© @DateTime.Now.Year Application Éducative</span>
            </